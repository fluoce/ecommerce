{
  "endOfLine": "lf",
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 100,
  "arrowParens": "always",
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindConfig": "tailwind.config.js",
  "tailwindAttributes": ["className", "class", "tw"],
  "tailwindFunctions": ["cn", "cva"]
}
