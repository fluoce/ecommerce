enum CategoryStatus {
  DRAFT
  ACTIVE
  INACTIVE
  DELETED
}

model Category {
  id               String         @id
  name             String
  description      String?
  slug             String         @unique
  sortOrder        String?
  parentId         String?
  parent           Category?      @relation("CategoryTree", fields: [parentId], references: [id])
  children         Category[]     @relation("CategoryTree")
  status           CategoryStatus @default(DRAFT)
  thumbnailAssetId String?
  thumbnailAsset   Asset?         @relation("CategoryThumbnail", fields: [thumbnailAssetId], references: [id])
  bannerAssetId    String?
  bannerAsset      Asset?         @relation("CategoryBanner", fields: [bannerAssetId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([parentId])
  @@index([status])
  @@index([thumbnailAssetId])
  @@index([bannerAssetId])
}
