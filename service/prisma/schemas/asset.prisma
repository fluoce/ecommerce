enum AssetStatus {
    TEMPORARY
    PROCESSING
    READY
    FAILED
    DELETED
}

enum AssetType {
    IMAGE
    VIDEO
}

enum AssetStorageProvider {
    S3
    R2
}

model Asset {
    id            String               @id
    type          AssetType
    provider      AssetStorageProvider @default(S3)
    originalKey   String
    tinyKey       String?
    thumbnailKey  String?
    mediumKey     String?
    largeKey      String?
    extraLargeKey String?
    fileName      String
    mimeType      String
    status        AssetStatus          @default(TEMPORARY)
    createdAt     DateTime             @default(now())
    updatedAt     DateTime             @updatedAt

    @@index([type])
    @@index([status])
}
